# Required: AgentMail (https://console.agentmail.to)
AGENTMAIL_API_KEY=am_...

# Required: OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-...

# Required: Neon Postgres - use the connection URL only (not the "psql '...'" command).
# In Vercel: Storage → your DB → use the POSTGRES_URL value (starts with postgresql://).
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: for scripts/setup-agentmail.ts (use your Vercel app URL after deploy)
WEBHOOK_URL=https://your-app.vercel.app/api/webhook/agentmail

# Optional: Google Sheets sync
GOOGLE_SHEETS_ID=1abc...xyz
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEET_NAME=Applications
